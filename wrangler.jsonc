{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wc26-3rd-place",
  "main": "worker/index.js",
  "compatibility_date": "2025-09-01",
  // Serves the Vite build in ./dist; the Worker (main) runs for non-asset paths
  // such as /api/standings and falls back to env.ASSETS for everything else.
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
